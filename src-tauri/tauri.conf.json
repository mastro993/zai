{
  "$schema": "https://schema.tauri.app/config/1",
  "build": {
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "productName": "MyFin",
  "mainBinaryName": "myfin-app",
  "version": "0.1.0",
  "identifier": "dev.fedemas.myfin.app",
  "plugins": {
    "sql": {
      "preload": ["sqlite:myfin.db"]
    }
  },
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "myfin-app",
        "width": 800,
        "height": 600,
        "useHttpsScheme": true
      }
    ]
  }
}
