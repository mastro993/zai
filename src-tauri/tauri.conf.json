{
  "$schema": "https://schema.tauri.app/config/1",
  "productName": "Zai",
  "mainBinaryName": "Zai",
  "version": "0.0.1",
  "identifier": "dev.fedemas.zai.app",
  "app": {
    "security": {
      "csp": null
    },
    "windows": [
      {
        "title": "Zai",
        "width": 1280,
        "height": 960,
        "minWidth": 480,
        "minHeight": 720,
        "useHttpsScheme": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "build": {
    "beforeDevCommand": "yarn run dev",
    "beforeBuildCommand": "yarn run build",
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420"
  },
  "plugins": {
    "sql": {
      "preload": ["sqlite:zai.db"]
    }
  }
}
