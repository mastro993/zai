{
  "$schema": "https://schema.tauri.app/config/1",
  "productName": "Zai",
  "mainBinaryName": "Zai",
  "version": "0.0.1-alpha.1",
  "identifier": "dev.fedemas.zai.app",
  "app": {
    "security": {
      "csp": {
        "default-src": "'self' asset: tauri: customprotocol:",
        "connect-src": "'self' ipc: http://ipc.localhost",
        "font-src": "'self' asset:",
        "img-src": "'self' asset: blob: data:",
        "style-src": "'self' 'unsafe-inline' asset:",
        "script-src": "'self' asset:"
      },
      "devCsp": {
        "default-src": "'self' asset: tauri: customprotocol:",
        "connect-src": "'self' ipc: http://ipc.localhost ws://127.0.0.1:1420 http://127.0.0.1:1420",
        "font-src": "'self' asset:",
        "img-src": "'self' asset: blob: data:",
        "style-src": "'self' 'unsafe-inline' asset:",
        "script-src": "'self' 'unsafe-inline' http://127.0.0.1:1420"
      },
      "capabilities": ["default"]
    },
    "windows": [
      {
        "label": "main",
        "title": "Zai",
        "width": 1280,
        "height": 960,
        "minWidth": 480,
        "minHeight": 720,
        "useHttpsScheme": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "build": {
    "beforeDevCommand": "pnpm --filter frontend dev",
    "beforeBuildCommand": "pnpm --filter frontend build",
    "frontendDist": "../../dist",
    "devUrl": "http://localhost:1420"
  },
  "plugins": {
    "fs": {
      "requireLiteralLeadingDot": false
    }
  }
}
