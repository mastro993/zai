{
  "name": "frontend",
  "private": true,
  "license": "GPL-3.0-only",
  "version": "0.0.1-alpha.1",
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "dev": "VITE_ZAI_BUILD_TARGET=tauri vite dev",
    "dev:web": "vite dev --mode web",
    "generate-routes": "tsr generate",
    "build": "pnpm generate-routes && pnpm type-check && VITE_ZAI_BUILD_TARGET=tauri vite build",
    "build:web": "pnpm generate-routes && pnpm type-check && vite build --mode web",
    "preview": "vite preview",
    "type-check": "tsc -b --noEmit",
    "lint": "oxlint src --deny-warnings",
    "lint:fix": "oxlint src --fix",
    "format": "oxfmt src",
    "format:check": "oxfmt src --check",
    "check:routes": "pnpm generate-routes && git diff --exit-code -- src/routeTree.gen.ts",
    "check": "pnpm format:check && pnpm lint && pnpm check:routes && pnpm type-check && pnpm test",
    "test": "VITE_ZAI_BUILD_TARGET=tauri vitest run"
  },
  "dependencies": {
    "@base-ui/react": "^1.6.0",
    "@fontsource-variable/inter": "^5.2.8",
    "@hookform/resolvers": "^5.4.0",
    "@hugeicons/core-free-icons": "^4.2.2",
    "@hugeicons/react": "^1.1.9",
    "@praha/byethrow": "^0.12.0",
    "@tailwindcss/vite": "^4.3.3",
    "@tanstack/react-devtools": "latest",
    "@tanstack/react-router": "latest",
    "@tanstack/react-router-devtools": "latest",
    "@tauri-apps/api": "~2.11.1",
    "@tauri-apps/plugin-dialog": "2.7.1",
    "@tauri-apps/plugin-fs": "2.5.1",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "color": "^5.0.3",
    "date-fns": "^4.4.0",
    "next-themes": "^0.4.6",
    "react": "^19.2.6",
    "react-day-picker": "^10.0.1",
    "react-dom": "^19.2.6",
    "react-hook-form": "^7.81.0",
    "shadcn": "^4.12.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.1.18",
    "tw-animate-css": "^1.4.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@tanstack/devtools-vite": "latest",
    "@tanstack/router-cli": "^1.132.0",
    "@tanstack/router-plugin": "^1.168.23",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/react": "^16.3.0",
    "@types/color": "^4.2.1",
    "@types/node": "^26.1.1",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^28.1.0",
    "oxfmt": "^0.60.0",
    "oxlint": "^1.74.0",
    "vite": "^8.1.5",
    "vitest": "^4.1.5"
  }
}
