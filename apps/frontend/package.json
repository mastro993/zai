    "@testing-library/react": "^16.3.0",
    "@types/node": "^22.13.9",
    "@types/react": "^19.2.6",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "jsdom": "^28.1.0",
    "oxfmt": "^0.45.0",
    "oxlint": "^1.60.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.5"
