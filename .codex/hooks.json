{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "node \".agents/skills/impeccable/scripts/hook.mjs\"",
            "timeout": 5,
            "statusMessage": "Checking UI changes"
          },
          {
            "type": "command",
            "command": "node scripts/check-hooks.mjs",
            "timeout": 60,
            "statusMessage": "Auto-fixing code quality"
          }
        ]
      }
    ]
  }
}
