{
  "hooks": {
    "SessionStart": [
      {
        "matcher": "startup|resume",
        "hooks": [
          {
            "type": "command",
            "command": "bash \".agents/hooks/install.sh\"",
            "timeout": 300,
            "statusMessage": "Installing dependencies"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Edit|Write|apply_patch",
        "hooks": [
          {
            "type": "command",
            "command": "node \".agents/skills/impeccable/scripts/hook.mjs\"",
            "timeout": 5,
            "statusMessage": "Checking UI changes"
          },
          {
            "type": "command",
            "command": "bash \".agents/hooks/format.sh\"",
            "timeout": 120,
            "statusMessage": "Format and lint autofix"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \".agents/hooks/check-gate.sh\"",
            "timeout": 900,
            "statusMessage": "Running repository checks"
          }
        ]
      }
    ]
  }
}
