{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "command": ".agents/hooks/install.sh",
        "timeout": 300
      }
    ],
    "afterFileEdit": [
       {
        "command": "[ ! -f \".cursor/skills/impeccable/scripts/hook-before-edit.mjs\" ] || node \".cursor/skills/impeccable/scripts/hook-before-edit.mjs\"",
        "timeout": 5
      },
      {
        "command": ".agents/hooks/format.sh",
        "timeout": 120
      }
    ],
    "stop": [
      {
        "command": ".agents/hooks/check-gate.sh",
        "timeout": 900,
        "loop_limit": 5
      }
    ]
  }
}
