# Copy to .env.web to override local web mode settings.
# Vite loads this file automatically with `vite dev --mode web`.
VITE_ZAI_API_ORIGIN=http://127.0.0.1:3000

# Persistent SQLite data directory for zai-server.
# Leave unset to use a temporary directory for each `pnpm dev:web` run.
ZAI_DATA_DIR=./.local/zai-web-data
