{
  "name": "zai-app",
  "private": true,
  "version": "0.0.1-alpha.1",
  "type": "module",
  "workspaces": [
    "apps/frontend"
  ],
  "scripts": {
    "prepare": "pnpm exec lefthook install",
    "dev": "pnpm --filter frontend dev",
    "dev:web": "node scripts/dev-web.mjs",
    "dev:tauri": "pnpm tauri dev",
    "build": "pnpm --filter frontend build",
    "build:web": "pnpm --filter frontend build:web",
    "preview": "pnpm --filter frontend preview",
    "tauri": "tauri",
    "build:tauri": "pnpm tauri build",
    "test": "pnpm frontend:test && pnpm backend:test && pnpm test:hooks",
    "test:hooks": "node --test scripts/check-hooks.test.mjs scripts/ensure-tauri-dist.test.mjs",
    "type-check": "pnpm frontend:type-check",
    "lint": "pnpm frontend:lint && pnpm backend:lint",
    "format": "pnpm frontend:format && pnpm backend:format",
    "format:check": "pnpm frontend:format:check && pnpm backend:format:check",
    "frontend:format": "pnpm --filter frontend format",
    "frontend:format:check": "pnpm --filter frontend format:check",
    "frontend:lint": "pnpm --filter frontend lint",
    "frontend:test": "pnpm --filter frontend test",
    "frontend:type-check": "pnpm --filter frontend type-check",
    "frontend:check:routes": "pnpm --filter frontend check:routes",
    "frontend:check": "pnpm frontend:format:check && pnpm frontend:lint && pnpm frontend:check:routes && pnpm frontend:type-check && pnpm frontend:test",
    "backend:prepare": "node scripts/ensure-tauri-dist.mjs",
    "backend:format": "cargo fmt --all",
    "backend:format:check": "cargo fmt --all --check",
    "backend:lint": "cargo clippy --workspace --all-targets --all-features -- -D warnings",
    "backend:test": "cargo test --workspace",
    "backend:check": "pnpm backend:prepare && pnpm backend:format:check && pnpm backend:lint && pnpm backend:test",
    "check": "pnpm frontend:check && pnpm backend:check",
    "check:hooks": "node scripts/check-hooks.mjs",
    "test:e2e:web": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@praha/byethrow-docs": "^0.12.0",
    "@praha/byethrow-oxlint": "^0.12.0",
    "@tauri-apps/cli": "^2.10.1",
    "lefthook": "^1.11.13",
    "typescript": "~5.6.2"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  }
}
