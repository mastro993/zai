{
  "name": "zai-app",
  "private": true,
  "version": "0.0.1-alpha.1",
  "type": "module",
  "workspaces": [
    "apps/frontend"
  ],
  "scripts": {
    "dev": "pnpm --filter frontend dev",
    "build": "pnpm --filter frontend build",
    "preview": "pnpm --filter frontend preview",
    "tauri": "tauri",
    "dev:tauri": "pnpm tauri dev",
    "build:tauri": "pnpm tauri build",
    "tsc:check": "tsc -b --noEmit",
    "lint": "pnpm --filter frontend lint",
    "format": "pnpm --filter frontend format",
    "format:check": "pnpm --filter frontend format:check",
    "check:routes": "pnpm --filter frontend generate-routes && git diff --exit-code apps/frontend/src/routeTree.gen.ts",
    "check": "pnpm tsc:check && pnpm lint && pnpm format:check && pnpm --filter frontend test && pnpm check:routes && cargo check --workspace && cargo test --workspace && cargo fmt --all --check"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.10.1",
    "typescript": "~5.6.2"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lightningcss"
    ]
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  }
}
