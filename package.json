{
  "name": "zai",
  "private": true,
  "license": "GPL-3.0-only",
  "version": "0.0.1-alpha.1",
  "type": "module",
  "workspaces": [
    "apps/frontend"
  ],
  "scripts": {
    "prepare": "pnpm exec lefthook install",
    "dev": "pnpm --filter frontend dev",
    "dev:web": "node scripts/dev-web.mjs",
    "dev:tauri": "pnpm tauri dev",
    "build": "pnpm --filter frontend build",
    "build:web": "pnpm --filter frontend build:web",
    "preview": "pnpm --filter frontend preview",
    "tauri": "tauri",
    "build:tauri": "pnpm tauri build",
    "test": "pnpm --filter frontend test",
    "type-check": "tsc -b --noEmit",
    "lint": "pnpm --filter frontend lint",
    "lint:fix": "pnpm --filter frontend lint:fix",
    "format": "pnpm --filter frontend format && cargo fmt --all",
    "format:check": "pnpm --filter frontend format:check && cargo fmt --all --check",
    "check:frontend": "pnpm --filter frontend check",
    "check:backend": "mkdir -p dist && printf '<!doctype html><html><body></body></html>' > dist/index.html && cargo fmt --all --check && cargo clippy --workspace --all-targets --all-features -- -D warnings && cargo build -p zai-db --bin recurring-crash-child --features failpoints && cargo test --workspace",
    "check:file-size": "node --test scripts/check-file-size.test.mjs && node scripts/check-file-size.mjs",
    "check": "pnpm check:file-size && pnpm check:frontend && pnpm check:backend",
    "test:e2e:web": "playwright test"
  },
  "devDependencies": {
    "@playwright/test": "^1.55.0",
    "@praha/byethrow-docs": "^0.12.0",
    "@praha/byethrow-oxlint": "^0.12.0",
    "@tauri-apps/cli": "~2.11.4",
    "lefthook": "^2.1.10",
    "typescript": "~5.6.2"
  },
  "packageManager": "pnpm@10.33.0",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook",
      "lightningcss"
    ],
    "ignoredBuiltDependencies": [
      "@tailwindcss/oxide",
      "esbuild",
      "sqlite3"
    ]
  },
  "dependencies": {
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^1.23.0",
    "shadcn": "^4.12.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  }
}
