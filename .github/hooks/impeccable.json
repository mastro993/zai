{
  "version": 1,
  "hooks": {
    "postToolUse": [
      {
        "type": "command",
        "matcher": "edit|create|apply_patch",
        "bash": "node \"$(git rev-parse --show-toplevel)/.github/skills/impeccable/scripts/hook.mjs\"",
        "timeoutSec": 5
      },
      {
        "type": "command",
        "matcher": "edit|create|apply_patch",
        "bash": "node \"$(git rev-parse --show-toplevel)/scripts/check-hooks.mjs\"",
        "timeoutSec": 60
      }
    ]
  }
}
